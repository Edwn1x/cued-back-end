# Copy this to .env and fill in your values

# Twilio (get these from twilio.com/console)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Anthropic API (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_api_key

# Database (SQLite for MVP, swap to Postgres later)
DATABASE_URL=sqlite:///baseline.db

# App
FLASK_SECRET_KEY=change-this-to-something-random
